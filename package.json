{
  "name": "@comapeo/default-categories",
  "version": "1.1.1",
  "description": "default set of categories to use in CoMapeo",
  "main": "dist/comapeo-default-categories.comapeocat",
  "scripts": {
    "build": "rimraf dist && mkdirp dist && comapeocat build --version ${npm_package_version} --addCategoryIdTags -o dist/comapeo-default-categories.comapeocat",
    "extract-messages": "mkdirp messages && comapeocat messages -o messages/en.json",
    "prepack": "npm run build",
    "test": "comapeocat lint .",
    "format": "prettier --write '**/*.{js,json,md}'",
    "prepare": "husky"
  },
  "devDependencies": {
    "comapeocat": "^1.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "mkdirp": "^3.0.1",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1"
  },
  "lint-staged": {
    "*.{js,json,md}": "prettier --write"
  },
  "keywords": [
    "comapeo"
  ],
  "author": "Tomás Ciccola",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/digidem/comapeo-default-categories.git"
  },
  "license": "CC-BY-NC-4.0",
  "homepage": "https://github.com/digidem/comapeo-default-categories#readme",
  "bugs": {
    "url": "https://github.com/digidem/comapeo-default-categories/issues"
  }
}
