{
  "name": "@comapeo/default-categories",
  "version": "0.0.1",
  "description": "default set of categories to use in CoMapeo",
  "main": "dist/mapeo-default-config.comapeocat",
  "scripts": {
    "build": "mkdirp build && comapeocat build --version ${npm_package_version} -o build/comapeo-default-categories-v${npm_package_version}.comapeocat",
    "build:dist": "comapeocat build --version ${npm_package_version} -o dist/comapeo-default-categories.comapeocat",
    "extract-messages": "mkdirp messages && comapeocat messages -o messages/en.json",
    "prepack": "rimraf dist && mkdirp dist && npm run -s build:dist",
    "test": "comapeocat lint ."
  },
  "devDependencies": {
    "comapeocat": "^1.1.0",
    "mkdirp": "^3.0.1",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1"
  },
  "keywords": [
    "comapeo"
  ],
  "author": "Tomás Ciccola",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/digidem/comapeo-default-categories.git"
  },
  "license": "CC-BY-NC-4.0",
  "homepage": "https://github.com/digidem/comapeo-default-categories#readme",
  "bugs": {
    "url": "https://github.com/digidem/comapeo-default-categories/issues"
  }
}
